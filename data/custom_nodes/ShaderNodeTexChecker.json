  "metadata": {
    "source_node": "ShaderNodeTexChecker",
    "source_engine": "Blender Cycles",
    "target_engine": "Unity",
    "target_version": "URP/HDRP",
    "conversion_rate": "70%",
    "description": "Procedural checkerboard pattern with scale, color, and offset control",
    "python_interpreter_version": "1.0",
    "complexity_level": "Medium-High",
    "primary_challenge": "Procedural math formula implementation and floating-point precision matching",
    "pattern_type": "Checkerboard (2x2 alternating squares)",
    "compatibility": "70%",
    "category": "Texture"
  },
  "summary": "Procedural checkerboard pattern with scale, color, and offset control",
  "unity_equivalent": "Checker",
  "implementation_notes": "Procedural checkerboard pattern",
  "procedural_pattern_overview": {
    "blender_algorithm": {
      "description": "Blender TexChecker generates a checkerboard by evaluating a mathematical formula on UV space",
      "formula": "checker = Step(0.5, Fraction(Floor(UV.x) + Floor(UV.y)))",
      "expanded_formula": "checker = (Fraction(Floor(UV.x) + Floor(UV.y)) >= 0.5) ? 1.0 : 0.0",
      "step_by_step": [
        {
          "step": 1,
          "operation": "Scale UV by checkerboard scale",
          "input": "UV coordinates [0, \u221e)",
          "output": "Scaled UV in checkerboard cell units"
        },
        {
          "step": 2,
          "operation": "Floor - convert to integer grid",
          "input": "Scaled UV [0, \u221e)",
          "output": "Integer grid position [0, 1, 2, 3, ...]",
          "purpose": "Determine which cell row/column"
        },
        {
          "step": 3,
          "operation": "Add Floor.x + Floor.y",
          "input": "Floor X and Y separately",
          "output": "Sum indicating diagonal parity",
          "purpose": "0+0=0 (even), 0+1=1 (odd), 1+0=1 (odd), 1+1=2 (even)"
        },
        {
          "step": 4,
          "operation": "Fraction - extract decimal part",
          "input": "Sum [0, 1, 2, ...]",
          "output": "[0.0, 0.5, 0.0, 0.5, ...]",
          "purpose": "Converts integer to deterministic pattern"
        },
        {
          "step": 5,
          "operation": "Step - binary threshold",
          "input": "Fraction value, threshold 0.5",
          "output": "[0.0 or 1.0] alternating",
          "purpose": "Creates sharp on/off checkerboard"
        },
        {
          "step": 6,
          "operation": "Lerp between Color 1 and Color 2",
          "input": "Step output [0, 1]",
          "output": "Final color",
          "purpose": "Color the two alternating squares"
        }
      ]
    },
    "why_70_percent": [
      {
        "issue": "Floating-point precision",
        "impact": "Minor differences in Fraction rounding between Blender and HLSL",
        "severity": "Low"
      },
      {
        "issue": "Limited procedural support",
        "impact": "Some edge cases with very large/small scale values",
        "severity": "Low"
      },
      {
        "issue": "No native Fraction node in standard ShaderGraph",
        "impact": "Must use custom function or approximation",
        "severity": "Medium"
      }
    ]
  },
