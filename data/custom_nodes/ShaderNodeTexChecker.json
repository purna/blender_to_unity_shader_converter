  "example_python_usage": {
    "description": "How Python script would generate this shader",
    "pseudo_code": [
      "import json",
      "",
      "# Load Blender shader",
      "blender_shader = parse_blender_file('material.blend')",
      "",
      "# Find TexChecker nodes",
      "checker_nodes = [n for n in blender_shader.nodes if n.type == 'ShaderNodeTexChecker']",
      "",
      "# Load solution config",
      "config = json.load(open('shader_graph_solution_TexChecker.json'))",
      "",
      "for checker in checker_nodes:",
      "    scale = checker.inputs['Scale'].default_value",
      "    color1 = checker.inputs['Color1'].default_value",
      "    color2 = checker.inputs['Color2'].default_value",
      "    ",
      "    # Validate parameters",
      "    if not (0.1 <= scale <= 1000.0):",
      "        print(f'WARNING: Scale {scale} out of range, clamping')",
      "        scale = max(0.1, min(1000.0, scale))",
      "    ",
      "    # Build shader graph",
      "    builder = ShaderGraphBuilder()",
      "    builder.create_uv_input()",
      "    builder.create_properties({",
      "        'Scale': ('Float', scale),",
      "        'Color1': ('Color', color1),",
      "        'Color2': ('Color', color2),",
      "        'Offset': ('Vector2', [0, 0])",
      "    })",
      "    ",
      "    # Create node chain following formula",
      "    builder.create_split_nodes()",
      "    builder.create_scale_chain()",
      "    builder.create_offset_chain()",
      "    builder.create_floor_nodes()",
      "    builder.create_parity_chain()",
      "    builder.create_fraction_node()",
      "    builder.create_step_node(0.5)",
      "    builder.create_lerp_colors()",
      "    ",
      "    # Validate formula path",
      "    if not builder.validate(config['validation_checks']):",
      "        print('Validation failed!')",
      "        continue",
      "    ",
      "    # Export",
      "    builder.export_to_unity('ProceduralChecker.shadergraph')"
    ]
  },
