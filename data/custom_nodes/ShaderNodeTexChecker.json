  "mathematical_formula_implementation": {
    "blender_formula": "Step(0.5, Frac(Floor(UV.x) + Floor(UV.y)))",
    "unity_equivalent": "step(0.5, frac(floor(scaled_uv.x) + floor(scaled_uv.y)))",
    "step_by_step_nodes": [
      {
        "step": 1,
        "operation": "Split UV into X, Y",
        "nodes": [
          "Split"
        ],
        "input": "UV [Vector2]",
        "output": "X, Y [Float]"
      },
      {
        "step": 2,
        "operation": "Scale by checkerboard density",
        "nodes": [
          "Multiply (\u00d7Scale)"
        ],
        "input": "X, Y [Float], Scale [Float]",
        "output": "Scaled X, Scaled Y [Float]"
      },
      {
        "step": 3,
        "operation": "Add offset",
        "nodes": [
          "Add"
        ],
        "input": "Scaled X, Y + Offset X, Y",
        "output": "Offset X, Y [Float]"
      },
      {
        "step": 4,
        "operation": "Integer grid floor",
        "nodes": [
          "Floor (CustomFunction)"
        ],
        "input": "Offset X, Y [Float]",
        "output": "Floor X, Floor Y [Integer as Float]"
      },
      {
        "step": 5,
        "operation": "Determine diagonal parity",
        "nodes": [
          "Add"
        ],
        "input": "Floor X, Floor Y [Float]",
        "output": "Sum [Float, range varies]"
      },
      {
        "step": 6,
        "operation": "Extract fractional part",
        "nodes": [
          "Fraction (CustomFunction)"
        ],
        "input": "Sum [Float]",
        "output": "Frac [Float, 0.0 to 1.0)"
      },
      {
        "step": 7,
        "operation": "Binary threshold",
        "nodes": [
          "Step"
        ],
        "input": "Frac [Float], Edge=0.5",
        "output": "[0.0 or 1.0]"
      },
      {
        "step": 8,
        "operation": "Color interpolation",
        "nodes": [
          "Lerp"
        ],
        "input": "Color1, Color2, Step output",
        "output": "Final Color [Vector4]"
      }
    ]
  },
