  "node_chain": {
    "description": "For simple 2D UV mapping, use TilingAndOffsetNode directly. For full 3D vector transformation, use node chain.",
    "simple_2d_mapping": {
      "description": "Use TilingAndOffsetNode for 2D UV coordinates",
      "nodes": [
        "TilingAndOffsetNode"
      ],
      "formula": "(UV * Tiling) + Offset"
    },
    "full_3d_mapping": {
      "description": "Use node chain for 3D vector transformation",
      "steps": [
        {
          "step": 1,
          "operation": "Scale",
          "nodes": [
            "MultiplyNode"
          ],
          "formula": "vector * scale"
        },
        {
          "step": 2,
          "operation": "Rotate",
          "nodes": [
            "RotateNode"
          ],
          "formula": "rotate(scaled_vector, rotation)"
        },
        {
          "step": 3,
          "operation": "Translate",
          "nodes": [
            "AddNode"
          ],
          "formula": "rotated_vector + location"
        }
      ],
      "recommended": "Use SubGraph from blender-nodes-for-unity3d package"
    }
  },
  "conversion_process": {
    "step_1": {
      "name": "Scale Vector",
      "description": "Multiply input by scale",
      "blender_input": "Vector, Scale",
      "unity_output": "Scaled vector"
    },
    "step_2": {
      "name": "Rotate Vector",
      "description": "Apply rotation to scaled vector",
      "blender_input": "Scaled vector, Rotation",
      "unity_output": "Rotated vector"
    },
    "step_3": {
      "name": "Translate Vector",
      "description": "Add location offset",
      "blender_input": "Rotated vector, Location",
      "unity_output": "Final transformed vector"
    }
  },
