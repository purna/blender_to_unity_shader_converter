        },
        {
          "step": 3,
          "operation": "Calculate Saturation",
          "input": "max, min",
          "output": "S (0-1)",
          "purpose": "Extract saturation"
        },
        {
          "step": 4,
          "operation": "Calculate Value",
          "input": "max",
          "output": "V (0-1)",
          "purpose": "Extract brightness"
        }
      ]
    }
