      {
        "node_id": "hsv_conversion",
        "node_type": "CodeFunctionNode",
        "category": "Math",
        "label": "RGB to HSV",
        "property_type": "None",
        "custom_function": {
          "name": "RGBtoHSV",
          "code": "float3 RGBtoHSV(float3 c) { float4 K = float4(0.0, -1.0/3.0, 2.0/3.0, -1.0); float4 p = lerp(float4(c.bg, K.wz), float4(c.gb, K.xy), step(c.b, c.g)); float4 q = lerp(float4(p.xyw, c.r), float4(c.r, p.yzx), step(p.x, c.r)); float d = q.x - min(q.w, q.y); float e = 1.0e-10; return float3(abs(q.z + (q.w - q.y) / (6.0 * d + e)), d / (q.x + e), q.x); }"
        },
        "inputs": [
          {
            "name": "c",
            "type": "Vector3"
          }
        ],
        "outputs": [
          {
            "name": "Out",
            "type": "Vector3"
          }
        ],
        "description": "Custom HLSL function for RGB to HSV conversion"
      }
    ],
    "connections": [
      {
        "connection_id": "conn_1",
        "from_node": "color_input",
        "from_output": "Out",
        "to_node": "split_rgb",
        "to_input": "In",
        "description": "Connect color to split"
      },
      {
        "connection_id": "conn_2",
        "from_node": "split_rgb",
