  "procedural_pattern_overview": {
    "blender_algorithm": {
      "description": "Convert RGB color to HSV components",
      "formula": "HSV = rgb2hsv(RGB)",
      "step_by_step": [
        {
          "step": 1,
          "operation": "Find max and min of RGB",
          "input": "R, G, B values",
          "output": "maxRGB, minRGB",
