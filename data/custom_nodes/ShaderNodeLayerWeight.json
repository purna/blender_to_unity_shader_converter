  "build_instructions_fresnel": [
    {
      "step": 1,
      "action": "CREATE_PROPERTY",
      "property": {
        "name": "Blend",
        "type": "Float",
        "default": 0.5,
        "range": [
          0,
          1
        ],
        "description": "Falloff sharpness"
      }
    },
    {
      "step": 2,
      "action": "CREATE_CONSTANTS",
      "constants": [
        {
          "value": 1.0,
          "node_label": "One"
        },
        {
          "value": 9.0,
          "node_label": "Nine"
        }
      ]
    },
    {
      "step": 3,
      "action": "CREATE_TRANSFORMATION_CHAIN",
      "chain": [
        "Blend Property",
        "Multiply node: Blend \u00d7 9.0",
        "Add node: (Blend \u00d7 9.0) + 1.0",
        "Result = Power value [1.0, 10.0]"
      ]
    },
    {
      "step": 4,
      "action": "CREATE_CUSTOM_FRESNEL",
      "note": "Use CustomFunction with HLSL code instead of standard Fresnel node",
      "code": "float3 viewDir = GetViewDirection(); float ndotv = abs(dot(normalize(normal), normalize(viewDir))); return pow(1.0 - ndotv, power);"
    },
    {
      "step": 5,
      "action": "WIRE_POWER_TRANSFORMATION",
      "connections": [
        "Blend \u2192 Multiply (9.0)",
        "Multiply out \u2192 Add (1.0)",
        "Add out \u2192 CustomFresnel (Power input)"
      ]
    },
    {
      "step": 6,
      "action": "OUTPUT_FRESNEL",
      "connection": "CustomFresnel output \u2192 Master or next stage"
    }
  ],
  "build_instructions_facing": [
    {
      "step": 1,
      "action": "CREATE_INPUT_NODES",
      "nodes": [
        "Normal Vector (Input > Geometry)",
        "View Direction (Input > Camera)",
        "Blend Property (Float, 0-1)"
      ]
    },
    {
      "step": 2,
      "action": "CREATE_DOT_PRODUCT_CHAIN",
      "chain": [
        "DotProduct node",
        "Absolute Value (custom function or Clamp 0-1)",
        "OneMinus node"
      ]
    },
    {
      "step": 3,
      "action": "WIRE_GEOMETRY_CHAIN",
      "connections": [
        "Normal \u2192 Dot (A)",
        "ViewDir \u2192 Dot (B)",
        "Dot out \u2192 Absolute",
        "Absolute out \u2192 OneMinus"
      ]
    },
    {
      "step": 4,
      "action": "APPLY_SHARPNESS",
      "note": "Optional: apply Blend as Power exponent",
      "chain": [
        "Power node",
        "OneMinus out \u2192 Power (Base)",
        "Blend \u2192 Power (Exponent)"
      ]
    },
    {
      "step": 5,
      "action": "OUTPUT_FACING",
      "connection": "Power output \u2192 Master or next stage"
    }
  ],
