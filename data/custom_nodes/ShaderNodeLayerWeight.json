  "validation_checks": [
    {
      "check_id": "v1",
      "name": "Blend Parameter Valid",
      "description": "Verify Blend is in [0.0, 1.0]",
      "python_code": "assert 0.0 <= blend <= 1.0, f'Blend {blend} out of range'"
    },
