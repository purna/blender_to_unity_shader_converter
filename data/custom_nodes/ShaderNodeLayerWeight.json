  "example_python_usage": {
    "description": "Complete conversion workflow",
    "pseudo_code": [
      "import json",
      "",
      "# Parse Blender shader",
      "blender_shader = parse_blend_file('material.blend')",
      "",
      "# Find LayerWeight nodes",
      "layer_weights = [n for n in blender_shader.nodes if n.type == 'ShaderNodeLayerWeight']",
      "",
      "# For each LayerWeight",
      "for lw_node in layer_weights:",
      "    blend = lw_node.inputs['Blend'].default_value",
      "    ",
      "    # Check which outputs are used",
      "    fresnel_connected = lw_node.outputs['Fresnel'].connected",
      "    facing_connected = lw_node.outputs['Facing'].connected",
      "    ",
      "    # Load configuration",
      "    config = json.load(open('shader_graph_solution_LayerWeight.json'))",
      "    ",
      "    # Build appropriate graph",
      "    if fresnel_connected:",
      "        builder = ShaderGraphBuilder()",
      "        builder.create_property('Blend', 'Float', blend)",
      "        ",
      "        # Transform blend to power",
      "        power = 1.0 + (blend * 9.0)",
      "        builder.create_custom_function('FresnelWithPower', ",
      "            inputs=['Normal', 'Power'],",
      "            code=config['shader_graph_fresnel_variant']['nodes'][...]['custom_function']['code']",
      "        )",
      "        ",
      "        # Wire transformation chain",
      "        builder.connect(blend_property, 'multiply_node', 9.0)",
      "        builder.connect('multiply', 'add_node', 1.0)",
      "        builder.connect('add', 'custom_fresnel', 'Power')",
      "        builder.connect('custom_fresnel', 'master', 'Emission or target')",
      "    ",
      "    if facing_connected:",
      "        # Build facing chain: Dot \u2192 OneMinus \u2192 Power",
      "        builder.create_node('DotProduct')",
      "        builder.create_node('OneMinus')",
      "        builder.create_node('Power')",
      "        builder.connect('dot', 'one_minus')",
      "        builder.connect('one_minus', 'power')",
      "        builder.connect(blend_property, 'power', 'Exponent')",
      "        builder.connect('power', 'master', 'target')",
      "    ",
      "    # Validate and export",
      "    if builder.validate(config['validation_checks']):",
      "        builder.export_to_unity()",
      "    else:",
      "        print('Validation failed!')"
    ]
  },
