{
  "metadata": {
    "source_node": "ShaderNodeLayerWeight",
    "source_engine": "Blender Cycles",
    "target_engine": "Unity",
    "target_version": "URP/HDRP",
    "conversion_rate": "75%",
    "description": "Fresnel and Facing view-angle blend weights with parameter transformation",
    "category": "Input",
    "complexity_level": "High"
  },
  "summary": "Fresnel and Facing view-angle blend weights with parameter transformation",
  "unity_equivalent": "Fresnel/Facing",
  "implementation_notes": "Blend/Fresnel nodes",
  "approximation": "Fresnel + Facing approximation",
  "node_overview": {
    "blender_description": "Layer Weight outputs two view-angle dependent weights: Fresnel (edge brightness) and Facing (surface orientation relative to view)",
    "blender_outputs": [
      {
        "name": "Fresnel",
        "description": "Value from 0 (surface perpendicular to view) to 1 (edge-on to view). Controls edge brightness/visibility."
      },
      {
        "name": "Facing",
        "description": "Value from 0 (facing camera directly) to 1 (surface edge-on). Useful for backface or edge effects."
      }
    ],
    "blender_parameters": [
      {
        "name": "Blend",
        "type": "Float",
        "range": [
          0.0,
          1.0
        ],
        "semantics": "Controls falloff sharpness between view angles",
        "description": "0.0 = sharp transition (flat), 1.0 = gradual soft transition"
      }
    ],
    "unity_approximation": "No single LayerWeight equivalent. Implement using Fresnel node + Dot Product formula.",
    "why_75_percent": "Fresnel output maps well (85%), but Facing requires custom math (60%), and Blend parameter needs transformation formula rather than direct mapping."
  },
  "parameter_transformation": {
    "blend_parameter_semantics": {
      "description": "Blender Blend controls the sharpness of the Fresnel/Facing falloff",
      "blender_range": [
        0.0,
        1.0
      ],
      "blender_semantics": {
        "0.0": "Sharp transition - Fresnel will go from 0 to 1 very abruptly",
        "0.5": "Default moderate blend - smooth natural Fresnel curve",
        "1.0": "Very soft transition - Fresnel spread across much larger view angle range"
      },
      "unity_mapping": {
        "description": "Transform Blend to Fresnel Power parameter",
        "formula": "FresnelPower = lerp(1.0, 10.0, Blend)",
        "explanation": "Blend=0.0 \u2192 Power=1.0 (very wide, soft falloff), Blend=1.0 \u2192 Power=10.0 (very tight, sharp falloff)",
        "alternate_formula": "FresnelPower = max(0.1, Blend * 10.0)",
        "mathematical_basis": "Fresnel Power controls the exponent in (1 - dot)^Power, affecting curvature"
      },
      "transformation_curve": {
        "visual_description": "Non-linear curve mapping Blend [0,1] to Power [1,10]",
        "key_points": [
          {
            "blend": 0.0,
            "power": 1.0,
            "appearance": "Maximum softness, very gradual edge glow"
          },
          {
            "blend": 0.25,
            "power": 3.25,
            "appearance": "Soft to moderate edge transition"
          },
          {
            "blend": 0.5,
            "power": 5.5,
            "appearance": "Moderate edge glow (natural looking)"
          },
          {
            "blend": 0.75,
            "power": 7.75,
            "appearance": "Sharp to tight edge concentration"
          },
          {
            "blend": 1.0,
            "power": 10.0,
            "appearance": "Maximum sharpness, concentrated at edges only"
          }
        ]
      },
      "python_formula": "power = 1.0 + (blend * 9.0)  # or: power = lerp(1.0, 10.0, blend)"
    }
  },
  "implementation_strategies": {
    "strategy_1_fresnel_output": {
      "name": "Fresnel Implementation",
      "description": "Map Blender LayerWeight Fresnel output to Unity Fresnel node",
      "compatibility": 85,
      "nodes_required": [
        "Fresnel",
        "Multiply (Blend to Power transform)"
      ],
      "workflow": [
        "Create Fresnel node",
        "Create Multiply node to convert Blend parameter to Power",
        "Wire Fresnel output directly as Fresnel weight"
      ],
      "limitations": "Fresnel Power can't be dynamically set from material property in standard ShaderGraph - must use custom function or pre-computed variants"
    },
    "strategy_2_facing_output": {
      "name": "Facing Implementation",
      "description": "Approximate Blender LayerWeight Facing using dot product math",
      "compatibility": 60,
      "nodes_required": [
        "Normal Vector",
        "View Direction",
        "Dot Product",
        "One Minus",
        "Power (optional, for sharpness)"
      ],
      "formula": "Facing \u2248 1.0 - saturate(dot(Normal, ViewDir))",
      "extended_formula": "Facing = (1.0 - saturate(dot(Normal, ViewDir)))^Blend_Power",
      "workflow": [
        "Get Normal Vector (geometry normal or custom)",
        "Get View Direction (camera view direction)",
        "Compute dot product",
        "Subtract from 1 to invert (closer to camera = smaller value)",
        "Optional: apply Power node with Blend-transformed power for sharpness control"
      ],
      "limitations": "Requires custom function or multiple nodes; exact Blender behavior hard to replicate without custom shader code"
    },
    "strategy_3_hybrid_custom_function": {
      "name": "Custom Function (Advanced)",
      "description": "Use custom HLSL function for exact Blender LayerWeight behavior",
      "compatibility": 90,
      "requires": "CustomFunction node with HLSL code",
      "hlsl_implementation": {
        "function_name": "BlenderLayerWeight",
        "inputs": [
          {
            "name": "Normal",
            "type": "float3"
          },
          {
            "name": "ViewDirection",
            "type": "float3"
          },
          {
            "name": "Blend",
            "type": "float"
          }
        ],
        "outputs": [
          {
            "name": "Fresnel",
            "type": "float"
          },
          {
            "name": "Facing",
            "type": "float"
          }
        ],
        "code": [
          "void BlenderLayerWeight(float3 normal, float3 viewDir, float blend,",
          "    out float fresnel, out float facing) {",
          "    float3 normN = normalize(normal);",
          "    float3 normV = normalize(viewDir);",
          "    ",
          "    // Fresnel: edge brightness",
          "    float ndotv = abs(dot(normN, normV));",
          "    float fresnelVal = 1.0 - ndotv;",
          "    float power = 1.0 + (blend * 9.0);  // blend [0,1] -> power [1,10]",
          "    fresnel = pow(fresnelVal, power);",
          "    ",
          "    // Facing: surface orientation relative to view",
          "    float facingVal = 1.0 - ndotv;  // Similar but without power transform",
          "    facing = facingVal;",
          "}"
        ]
      },
      "notes": "Best accuracy but requires shader code understanding from conversion script"
    }
  },
  "shader_graph_fresnel_variant": {
    "name": "LayerWeight_FreshnelOnly_Shader",
    "type": "UniversalRenderPipeline/Lit",
    "description": "Implements Fresnel output of Layer Weight for edge glow effects",
    "target_output": "Float value [0, 1] representing edge brightness",
    "nodes": [
      {
        "node_id": "blend_property",
        "node_type": "Property",
        "category": "Input",
        "label": "Blend",
        "property_name": "_BlendFalloff",
        "property_type": "Float",
        "default_value": 0.5,
        "min_value": 0.0,
        "max_value": 1.0,
        "outputs": [
          {
            "name": "Out",
            "type": "Float"
          }
        ],
        "description": "Controls falloff sharpness (0=soft, 1=sharp)"
      },
      {
        "node_id": "blend_to_power",
        "node_type": "Multiply",
        "category": "Operator",
        "label": "Blend \u00d7 9.0",
        "inputs": [
          {
            "name": "A",
            "type": "Float"
          },
          {
            "name": "B",
            "type": "Float"
          }
        ],
        "outputs": [
          {
            "name": "Out",
            "type": "Float"
          }
        ],
        "description": "Scale Blend by 9.0 (will be added to 1.0 later)"
      },
      {
        "node_id": "add_power_offset",
        "node_type": "Add",
        "category": "Operator",
        "label": "Power + 1.0",
        "inputs": [
          {
            "name": "A",
            "type": "Float"
          },
          {
            "name": "B",
            "type": "Float"
          }
        ],
        "outputs": [
          {
            "name": "Out",
            "type": "Float"
          }
        ],
        "description": "Add 1.0 to get final power value (range 1.0-10.0)"
      },
      {
        "node_id": "power_constant",
        "node_type": "Float",
        "category": "Input",
        "label": "Constant 1.0",
        "value": 1.0,
        "outputs": [
          {
            "name": "Out",
            "type": "Float"
          }
        ]
      },
      {
        "node_id": "scale_constant",
        "node_type": "Float",
        "category": "Input",
        "label": "Constant 9.0",
        "value": 9.0,
        "outputs": [
          {
            "name": "Out",
            "type": "Float"
          }
        ]
      },
      {
        "node_id": "fresnel_node",
        "node_type": "Fresnel",
        "category": "Lighting",
        "label": "Fresnel",
        "inputs": [
          {
            "name": "Normal",
            "type": "Vector3"
          }
        ],
        "outputs": [
          {
            "name": "Out",
            "type": "Float"
          }
        ],
        "properties": [
          {
            "name": "Power",
            "type": "Float",
            "default": 5.0,
            "description": "Note: This is static in standard ShaderGraph. Use custom function for dynamic power based on Blend."
          }
        ],
        "limitation_note": "Standard Fresnel node has fixed Power property. For dynamic Blend control, use CustomFunction instead."
      },
      {
        "node_id": "custom_fresnel",
        "node_type": "CustomFunction",
        "category": "Utility",
        "label": "Fresnel with Dynamic Power",
        "inputs": [
          {
            "name": "Normal",
            "type": "Vector3"
          },
          {
            "name": "Power",
            "type": "Float"
          }
        ],
        "outputs": [
          {
            "name": "Out",
            "type": "Float"
          }
        ],
        "custom_function": {
          "name": "FresnelWithPower",
          "code": [
            "float FresnelWithPower(float3 normal, float power) {",
            "    float3 viewDir = GetViewDirection();",
            "    float ndotv = abs(dot(normalize(normal), normalize(viewDir)));",
            "    return pow(1.0 - ndotv, power);",
            "}"
          ]
        },
        "recommended": true,
        "description": "Custom function implementation for fully dynamic Fresnel with Blend control"
      }
    ],
    "connections_fresnel": [
      {
        "connection_id": "conn_1",
        "from_node": "blend_property",
        "from_output": "Out",
        "to_node": "blend_to_power",
        "to_input": "A",
        "description": "Blend value to multiply by 9.0"
      },
      {
        "connection_id": "conn_2",
        "from_node": "scale_constant",
        "from_output": "Out",
        "to_node": "blend_to_power",
        "to_input": "B",
        "description": "9.0 constant"
      },
      {
        "connection_id": "conn_3",
        "from_node": "blend_to_power",
        "from_output": "Out",
        "to_node": "add_power_offset",
        "to_input": "A",
        "description": "Blend \u00d7 9.0 to add node"
      },
      {
        "connection_id": "conn_4",
        "from_node": "power_constant",
        "from_output": "Out",
        "to_node": "add_power_offset",
        "to_input": "B",
        "description": "Add offset of 1.0"
      },
      {
        "connection_id": "conn_5",
        "from_node": "add_power_offset",
        "from_output": "Out",
        "to_node": "custom_fresnel",
        "to_input": "Power",
        "description": "Final power [1.0-10.0] to Fresnel"
      },
      {
        "connection_id": "conn_6",
        "from_node": "custom_fresnel",
        "from_output": "Out",
        "to_node": "master_node",
        "to_input": "Emission or output property",
        "description": "Fresnel weight output"
      }
    ]
  },
