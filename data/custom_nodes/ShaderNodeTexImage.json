{
  "metadata": {
    "source_node": "ShaderNodeTexImage",
    "source_engine": "Blender Cycles",
    "target_engine": "Unity",
    "target_version": "URP/HDRP",
    "conversion_rate": "95%",
    "description": "2D texture sampling with full UV/sampler state control and asset migration strategy",
    "python_interpreter_version": "1.0",
    "complexity_level": "Medium",
    "primary_challenge": "Texture asset reference resolution and sampler state mapping"
  },
  "asset_migration": {
    "blender_to_unity_texture_flow": {
      "step_1_export_from_blender": {
        "action": "Export texture from Blender",
        "menu_path": "Image > Save As",
        "recommended_format": "PNG or TGA (for lossless)",
        "naming_convention": "{texture_name}_BaseMap.png",
        "color_space_preservation": "Linear vs sRGB handled in export",
        "example": "wood_diffuse.png becomes wood_diffuse_BaseMap.png"
      },
      "step_2_import_to_unity": {
        "action": "Import into Unity Assets folder",
        "folder_structure": "Assets/Textures/{material_name}/",
        "import_settings": [
          "Texture Type: Default or Normal Map",
          "sRGB (Color Texture): Match Blender color space",
          "Compression: Depends on target platform",
          "Filter Mode: Will be overridden by Sampler State"
        ],
        "example_path": "Assets/Textures/Wood/wood_diffuse_BaseMap.png"
      },
      "step_3_reference_in_shader": {
        "action": "Assign texture to Sample Texture 2D node",
        "assignment_method": "Material Inspector or Property Block",
        "runtime_assignment": "renderer.material.SetTexture('_MainTex', textureAsset)",
        "automatic_detection": "Python script can scan Assets folder for matching files"
      }
    },
    "texture_naming_convention": {
      "description": "Standardized naming for Python asset resolution",
      "pattern": "{base_name}_{texture_type}.{format}",
      "texture_type_suffixes": {
        "BaseMap": "Diffuse/Color texture",
        "NormalMap": "Normal direction texture",
        "MetallicMap": "Metallic properties",
        "RoughnessMap": "Roughness/Smoothness",
        "AOMap": "Ambient Occlusion",
        "EmissionMap": "Self-illumination"
      },
      "examples": [
        "fabric_BaseMap.png",
        "fabric_NormalMap.png",
        "metal_MetallicMap.png",
        "concrete_RoughnessMap.png"
      ]
    }
  },
  "shader_graph": {
    "name": "TextureSampling_Shader",
    "type": "UniversalRenderPipeline/Lit",
    "description": "Complete 2D texture sampling with UV mapping and sampler state control",
    "target_output": "Master (Base Color + Normal + Metallic + Smoothness)",
    "nodes": [
      {
        "node_id": "texture_property",
        "node_type": "Property",
        "category": "Input",
        "label": "Main Texture",
        "property_name": "_MainTex",
        "property_type": "Texture2D",
        "outputs": [
          {
            "name": "Out",
            "type": "Texture2D"
          }
        ],
        "description": "2D texture asset reference",
        "blender_mapping": "Image"
      },
      {
        "node_id": "uv_input",
        "node_type": "UV",
        "category": "Input",
        "label": "UV Coordinates",
        "uv_channel": 0,
        "outputs": [
          {
            "name": "Out",
            "type": "Vector2"
          }
        ],
        "description": "Default UV channel (can be changed to UV 1, 2, etc.)",
        "blender_mapping": "Vector (defaults to active UV)"
      },
      {
        "node_id": "uv_scale",
        "node_type": "Property",
        "category": "Input",
        "label": "UV Scale",
        "property_name": "_UVScale",
        "property_type": "Vector2",
        "default_value": [1.0, 1.0],
        "outputs": [
          {
            "name": "Out",
            "type": "Vector2"
          }
        ],
        "description": "Texture tiling scale multiplier"
      },
      {
        "node_id": "uv_offset",
        "node_type": "Property",
        "category": "Input",
        "label": "UV Offset",
        "property_name": "_UVOffset",
        "property_type": "Vector2",
        "default_value": [0.0, 0.0],
        "outputs": [
          {
            "name": "Out",
            "type": "Vector2"
          }
        ],
        "description": "Texture pan offset for animation"
      },
      {
        "node_id": "multiply_scale",
        "node_type": "Multiply",
        "category": "Operator",
        "label": "UV × Scale",
        "inputs": [
          {
            "name": "A",
            "type": "Vector2"
          },
          {
            "name": "B",
            "type": "Vector2"
          }
        ],
        "outputs": [
          {
            "name": "Out",
            "type": "Vector2"
          }
        ],
        "description": "Apply tiling to UV coordinates"
      },
      {
        "node_id": "add_offset",
        "node_type": "Add",
        "category": "Operator",
        "label": "UV + Offset",
        "inputs": [
          {
            "name": "A",
            "type": "Vector2"
          },
          {
            "name": "B",
            "type": "Vector2"
          }
        ],
        "outputs": [
          {
            "name": "Out",
            "type": "Vector2"
          }
        ],
        "description": "Apply offset/pan to UV coordinates"
      },
      {
        "node_id": "sampler_state",
        "node_type": "SamplerState",
        "category": "Texture",
        "label": "Sampler State",
        "outputs": [
          {
            "name": "Out",
            "type": "SamplerState"
          }
        ],
        "properties": [
          {
            "name": "Filter Mode",
            "type": "Enum",
            "values": [
              "Point",
              "Linear",
              "Trilinear"
            ],
            "default": "Linear",
            "blender_mapping": {
              "Linear": "Blender Linear (default)",
              "Point": "Blender Closest",
              "Trilinear": "Blender Linear (mipmapped)"
            },
            "note": "Blender Cubic and Smart have no direct Unity equivalent"
          },
          {
            "name": "Wrap Mode",
            "type": "Enum",
            "values": [
              "Repeat",
              "Mirror",
              "Clamp"
            ],
            "default": "Repeat",
            "blender_mapping": {
              "Repeat": "Blender Repeat",
              "Mirror": "Blender Mirror",
              "Clamp": "Blender Clip (mapped to Clamp)"
            }
          }
        ],
        "description": "Controls texture filtering and wrapping behavior"
      },
      {
        "node_id": "sample_texture_color",
        "node_type": "SampleTexture2D",
        "category": "Texture",
        "label": "Sample Texture 2D",
        "inputs": [
          {
            "name": "Texture",
            "type": "Texture2D"
          },
          {
            "name": "UV",
            "type": "Vector2"
          },
          {
            "name": "Sampler",
            "type": "SamplerState"
          }
        ],
        "outputs": [
          {
            "name": "RGBA",
            "type": "Vector4"
          },
          {
            "name": "RGB",
            "type": "Vector3"
          },
          {
            "name": "A",
            "type": "Float"
          }
        ],
        "properties": [
          {
            "name": "Type",
            "type": "Enum",
            "values": [
              "Default",
              "Normal"
            ],
            "default": "Default",
            "description": "Set to Normal if texture is a normal map"
          }
        ],
        "description": "Samples 2D texture at UV coordinates with sampler state"
      },
      {
        "node_id": "output_color",
        "node_type": "Property",
        "category": "Output",
        "label": "Color Output",
        "property_name": "_BaseColor",
        "property_type": "Color",
        "default_value": [1.0, 1.0, 1.0, 1.0],
        "outputs": [
          {
            "name": "Out",
            "type": "Vector4"
          }
        ],
        "description": "Tint/multiply color for texture",
        "blender_note": "Blender TexImage outputs directly; Unity often multiplies by a property color"
      },
      {
        "node_id": "multiply_tint",
        "node_type": "Multiply",
        "category": "Operator",
        "label": "Texture × Tint",
        "inputs": [
          {
            "name": "A",
            "type": "Vector4"
          },
          {
            "name": "B",
            "type": "Vector4"
          }
        ],
        "outputs": [
          {
            "name": "Out",
            "type": "Vector4"
          }
        ],
        "description": "Apply color tint to sampled texture"
      }
    ],
    "connections": [
      {
        "connection_id": "conn_1",
        "from_node": "uv_input",
        "from_output": "Out",
        "to_node": "multiply_scale",
        "to_input": "A",
        "description": "UV to scale multiplication"
      },
      {
        "connection_id": "conn_2",
        "from_node": "uv_scale",
        "from_output": "Out",
        "to_node": "multiply_scale",
        "to_input": "B",
        "description": "Scale factor to multiplication"
      },
      {
        "connection_id": "conn_3",
        "from_node": "multiply_scale",
        "from_output": "Out",
        "to_node": "add_offset",
        "to_input": "A",
        "description": "Scaled UV to offset addition"
      },
      {
        "connection_id": "conn_4",
        "from_node": "uv_offset",
        "from_output": "Out",
        "to_node": "add_offset",
        "to_input": "B",
        "description": "Offset to offset addition"
      },
      {
        "connection_id": "conn_5",
        "from_node": "texture_property",
        "from_output": "Out",
        "to_node": "sample_texture_color",
        "to_input": "Texture",
        "description": "Texture asset to sampler"
      },
      {
        "connection_id": "conn_6",
        "from_node": "add_offset",
        "from_output": "Out",
        "to_node": "sample_texture_color",
        "to_input": "UV",
        "description": "Transformed UV to sampler"
      },
      {
        "connection_id": "conn_7",
        "from_node": "sampler_state",
        "from_output": "Out",
        "to_node": "sample_texture_color",
        "to_input": "Sampler",
        "description": "Sampler state to texture sampler"
      },
      {
        "connection_id": "conn_8",
        "from_node": "sample_texture_color",
        "from_output": "RGBA",
        "to_node": "multiply_tint",
        "to_input": "A",
        "description": "Sampled color to tint multiplication"
      },
      {
        "connection_id": "conn_9",
        "from_node": "output_color",
        "from_output": "Out",
        "to_node": "multiply_tint",
        "to_input": "B",
        "description": "Tint color to multiplication"
      },
      {
        "connection_id": "conn_10",
        "from_node": "multiply_tint",
        "from_output": "Out",
        "to_node": "master_node",
        "to_input": "Base Color",
        "description": "Final color to material output"
      }
    ]
  },
  "blender_to_unity_parameter_mapping": [
    {
      "blender_parameter": "Image",
      "unity_implementation": "texture_property",
      "unity_nodes": ["Property (Texture2D)"],
      "conversion_formula": "texture_property = Find(Assets/Textures, blender_image_name)",
      "compatibility_percentage": 100,
      "challenges": [
        {
          "issue": "Automatic asset resolution",
          "solution": "Python script scans Assets folder using naming convention"
        },
        {
          "issue": "Blender path includes folder structure",
          "solution": "Extract filename only and search in Assets folder"
        }
      ],
      "python_implementation": "texture_asset = find_texture_in_assets(blender_image_name, 'Assets/Textures')"
    },
    {
      "blender_parameter": "Vector (UV)",
      "unity_implementation": [
        "uv_input",
        "uv_scale",
        "uv_offset",
        "multiply_scale",
        "add_offset"
      ],
      "unity_nodes": [
        "UV",
        "Property (Vector2)",
        "Property (Vector2)",
        "Multiply",
        "Add"
      ],
      "conversion_formula": "final_uv = (uv_input * uv_scale) + uv_offset",
      "compatibility_percentage": 100,
      "notes": "Blender defaults to active UV; Unity can select different channels (0-3)"
    },
    {
      "blender_parameter": "Interpolation",
      "unity_implementation": "sampler_state (Filter Mode)",
      "unity_nodes": ["SamplerState"],
      "blender_values": [
        {
          "blender": "Linear",
          "unity": "Linear",
          "compatibility": 100
        },
        {
          "blender": "Closest",
          "unity": "Point",
          "compatibility": 100
        },
        {
          "blender": "Cubic",
          "unity": "Linear or Trilinear",
          "compatibility": 60,
          "note": "Cubic spline not available; use Trilinear as approximation"
        },
        {
          "blender": "Smart",
          "unity": "Linear",
          "compatibility": 50,
          "note": "Smart adaptive filtering not available; default to Linear"
        }
      ],
      "overall_compatibility": 85
    },
    {
      "blender_parameter": "Projection",
      "unity_implementation": "None",
      "unity_nodes": [],
      "blender_values": [
        {
          "blender": "Flat",
          "unity": "Standard UV sampling",
          "compatibility": 100
        },
        {
          "blender": "Box",
          "unity": "No direct equivalent",
          "compatibility": 0,
          "workaround": "Use shader math to generate box projection UVs, or use triplanar mapping"
        },
        {
          "blender": "Sphere",
          "unity": "No direct equivalent",
          "compatibility": 0,
          "workaround": "Calculate spherical UVs from world position + normal"
        },
        {
          "blender": "Tube",
          "unity": "No direct equivalent",
          "compatibility": 0,
          "workaround": "Use custom cylindrical UV generation in shader"
        }
      ],
      "overall_compatibility": 25,
      "note": "Projection modes are a primary source of the 5% compatibility loss"
    },
    {
      "blender_parameter": "Extension",
      "unity_implementation": "sampler_state (Wrap Mode)",
      "unity_nodes": ["SamplerState"],
      "blender_values": [
        {
          "blender": "Repeat",
          "unity": "Repeat",
          "compatibility": 100
        },
        {
          "blender": "Extend",
          "unity": "Clamp",
          "compatibility": 95,
          "note": "Extend (last pixel) vs Clamp (edges) slightly different but visually similar"
        },
        {
          "blender": "Clip",
          "unity": "Clamp",
          "compatibility": 90,
          "note": "Clip (transparent) mapped to Clamp; set alpha to 0 manually if needed"
        },
        {
          "blender": "Mirror",
          "unity": "Mirror",
          "compatibility": 100
        }
      ],
      "overall_compatibility": 96
    },
    {
      "blender_parameter": "Color Space",
      "unity_implementation": "Texture Import Settings",
      "unity_nodes": [],
      "blender_values": [
        {
          "blender": "sRGB",
          "unity": "sRGB (Color Texture) = ON",
          "compatibility": 100,
          "note": "Set in Inspector: Texture Type > Default, sRGB enabled"
        },
        {
          "blender": "Non-Color",
          "unity": "sRGB (Color Texture) = OFF",
          "compatibility": 100,
          "note": "Use for data textures: roughness, metallic, normal maps, etc."
        }
      ],
      "overall_compatibility": 100,
      "python_implementation": "Set texture import settings based on texture_type detection"
    }
  ],
  "build_instructions": [
    {
      "step": 1,
      "action": "PREPARE_TEXTURE_ASSETS",
      "substeps": [
        {
          "action": "Export texture from Blender",
          "menu": "Image > Save As",
          "format": "PNG recommended",
          "location": "Save to project Assets/Textures/{material}/"
        },
        {
          "action": "Configure texture import settings in Unity",
          "settings": [
            "Texture Type: Default (or Normal for normal maps)",
            "sRGB (Color Texture): Toggle based on color space",
            "Compression: Choose per platform (BC7 for high quality)"
          ]
        }
      ]
    },
    {
      "step": 2,
      "action": "CREATE_PROPERTY_NODES",
      "nodes": [
        {
          "name": "Main Texture",
          "type": "Texture2D",
          "property": "_MainTex",
          "location": [100, 300]
        },
        {
          "name": "Base Color",
          "type": "Color",
          "property": "_BaseColor",
          "default": [1, 1, 1, 1],
          "location": [100, 200]
        },
        {
          "name": "UV Scale",
          "type": "Vector2",
          "property": "_UVScale",
          "default": [1, 1],
          "location": [100, 100]
        },
        {
          "name": "UV Offset",
          "type": "Vector2",
          "property": "_UVOffset",
          "default": [0, 0],
          "location": [100, 0]
        }
      ]
    },
    {
      "step": 3,
      "action": "CREATE_INPUT_NODES",
      "nodes": [
        {
          "name": "UV Coordinates",
          "type": "UV",
          "uv_channel": 0,
          "location": [100, 400]
        }
      ]
    },
    {
      "step": 4,
      "action": "CREATE_SAMPLER_STATE",
      "node": {
        "name": "Sampler State",
        "type": "SamplerState",
        "filter_mode": "Linear",
        "wrap_mode": "Repeat",
        "location": [300, 200],
        "note": "Configure based on Blender Interpolation and Extension settings"
      }
    },
    {
      "step": 5,
      "action": "CREATE_UV_TRANSFORMATION",
      "nodes": [
        {
          "name": "Multiply (UV × Scale)",
          "type": "Multiply",
          "location": [300, 400]
        },
        {
          "name": "Add (UV + Offset)",
          "type": "Add",
          "location": [500, 400]
        }
      ]
    },
    {
      "step": 6,
      "action": "CREATE_TEXTURE_SAMPLER",
      "node": {
        "name": "Sample Texture 2D",
        "type": "SampleTexture2D",
        "type_setting": "Default (or Normal if normal map)",
        "location": [700, 300]
      }
    },
    {
      "step": 7,
      "action": "CREATE_TINT_MULTIPLIER",
      "node": {
        "name": "Multiply (Texture × Tint)",
        "type": "Multiply",
        "location": [900, 300]
      }
    },
    {
      "step": 8,
      "action": "WIRE_UV_CHAIN",
      "connections": [
        "UV → Multiply (A)",
        "UV Scale → Multiply (B)",
        "Multiply Out → Add (A)",
        "UV Offset → Add (B)",
        "Add Out → Sample Texture 2D (UV)"
      ]
    },
    {
      "step": 9,
      "action": "WIRE_TEXTURE_CHAIN",
      "connections": [
        "Main Texture → Sample Texture 2D (Texture)",
        "Sampler State → Sample Texture 2D (Sampler)",
        "Sample Texture 2D (RGBA) → Multiply Tint (A)",
        "Base Color → Multiply Tint (B)",
        "Multiply Tint Out → Master (Base Color)"
      ]
    },
    {
      "step": 10,
      "action": "CONFIGURE_SAMPLER_STATE",
      "mapping": [
        {
          "blender_setting": "Interpolation",
          "action": "Set Filter Mode",
          "rules": [
            "Linear → Linear",
            "Closest → Point",
            "Cubic → Trilinear",
            "Smart → Linear"
          ]
        },
        {
          "blender_setting": "Extension",
          "action": "Set Wrap Mode",
          "rules": [
            "Repeat → Repeat",
            "Extend → Clamp",
            "Clip → Clamp",
            "Mirror → Mirror"
          ]
        }
      ]
    },
    {
      "step": 11,
      "action": "HANDLE_SPECIAL_CASES",
      "cases": [
        {
          "case": "Normal Map Input",
          "action": "Set Sample Texture 2D Type to 'Normal'",
          "note": "Automatically converts sRGB to linear and applies proper normal decoding"
        },
        {
          "case": "Projection = Box/Sphere/Tube",
          "action": "Create custom projection nodes",
          "workaround": "Use separate shader with triplanar or projection math"
        },
        {
          "case": "Interpolation = Cubic/Smart",
          "action": "Select best approximation",
          "choice": "Use Trilinear for Cubic, Linear for Smart"
        }
      ]
    }
  ],
  "python_interpreter_config": {
    "script_type": "TextureImportAndShaderBuilder",
    "required_libraries": [
      "json",
      "pathlib",
      "os",
      "re"
    ],
    "workflow": {
      "phase_1_asset_discovery": [
        "Scan Blender .blend file for TexImage nodes",
        "Extract texture image names and paths",
        "Build texture_list = [{name, blender_path, color_space, interpolation, extension, projection}]"
      ],
      "phase_2_asset_matching": [
        "For each texture in texture_list:",
        "Search Assets/Textures recursively for matching filename",
        "If not found: log error and suggest manual import",
        "Build unity_texture_assets = [{blender_name, unity_path, asset_guid}]"
      ],
      "phase_3_import_configuration": [
        "For each texture in unity_texture_assets:",
        "Determine import settings from Blender metadata",
        "color_space = 'sRGB' if blender.color_space == 'sRGB' else 'Linear'",
        "texture_type = 'Normal' if '_NormalMap' in filename else 'Default'",
        "Generate Unity texture importer metadata"
      ],
      "phase_4_shader_generation": [
        "For each texture, generate shader graph JSON section",
        "Apply sampler_state_mapping based on interpolation/extension",
        "Check for unsupported projections and log warnings",
        "Generate final shader graph with all connections"
      ]
    },
    "key_functions": {
      "find_texture_asset": "Recursively search Assets folder, return path or None",
      "parse_blender_texture_metadata": "Extract interpolation, extension, projection from Blender node",
      "map_interpolation_to_sampler": "Linear/Closest/Cubic/Smart → Point/Linear/Trilinear",
      "map_extension_to_wrap": "Repeat/Extend/Clip/Mirror → Repeat/Clamp/Clamp/Mirror",
      "detect_texture_type": "Check filename suffix to determine if Normal/Color/Data",
      "validate_projection": "Warn if projection != Flat (Box/Sphere/Tube not supported)"
    },
    "error_handling": {
      "texture_not_found": {
        "severity": "Error",
        "message": "Texture '{name}' not found in Assets folder",
        "action": "Log and skip; require manual assignment",
        "suggest": "Import texture to Assets/Textures/{material}/"
      },
      "unsupported_projection": {
        "severity": "Warning",
        "message": "Projection mode '{mode}' not directly supported",
        "action": "Use Flat (UV) mode; document workaround needed",
        "suggest": "Use triplanar mapping shader for Box/Sphere projections"
      },
      "unsupported_interpolation": {
        "severity": "Warning",
        "message": "Interpolation '{mode}' has no direct equivalent",
        "action": "Map to closest approximation",
        "mapping": {
          "Cubic": "Trilinear",
          "Smart": "Linear"
        }
      },
      "color_space_mismatch": {
        "severity": "Warning",
        "message": "Texture imported with sRGB=false but marked as Non-Color",
        "action": "Verify import settings in Unity Inspector"
      }
    }
  },
  "validation_checks": [
    {
      "check_id": "v1",
      "name": "Texture Asset Exists",
      "description": "Verify texture file exists at resolved path",
      "python_code": "assert os.path.exists(texture_asset_path), f'Texture {texture_asset_path} not found'"
    },
    {
      "check_id": "v2",
      "name": "UV Connections Valid",
      "description": "Ensure UV chain connects properly",
      "python_code": "assert 'UV' in nodes and 'Multiply' in nodes and 'Add' in nodes"
    },
    {
      "check_id": "v3",
      "name": "Sampler State Configured",
      "description": "Verify sampler state has valid filter and wrap modes",
      "python_code": "assert sampler_state.filter in ['Point', 'Linear', 'Trilinear'] and sampler_state.wrap in ['Repeat', 'Clamp', 'Mirror']"
    },
    {
      "check_id": "v4",
      "name": "Sample Texture Node Wired",
      "description": "Ensure all inputs to Sample Texture 2D are connected",
      "python_code": "assert sample_texture_node.inputs['Texture'].connected and sample_texture_node.inputs['UV'].connected"
    },
    {
      "check_id": "v5",
      "name": "No Unsupported Projections",
      "description": "Warn if projection mode is not Flat",
      "python_code": "if projection != 'Flat': print('WARNING: Projection mode {projection} requires custom implementation')"
