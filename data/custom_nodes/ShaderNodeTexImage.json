  "example_python_usage": {
    "description": "Python workflow for texture discovery and shader generation",
    "pseudo_code": [
      "import json, os",
      "from pathlib import Path",
      "",
      "# Load Blender shader node data",
      "blender_shader = parse_blender_shader('material.blend')",
      "",
      "# Find all TexImage nodes",
      "tex_image_nodes = [n for n in blender_shader.nodes if n.type == 'ShaderNodeTexImage']",
      "",
      "# Build texture list with metadata",
      "textures = []",
      "for node in tex_image_nodes:",
      "    texture_info = {",
      "        'blender_name': node.image.name,",
      "        'interpolation': node.interpolation,",
      "        'projection': node.projection,",
      "        'extension': node.extension,",
      "        'color_space': node.color_space",
      "    }",
      "    textures.append(texture_info)",
      "",
      "# Find matching Unity assets",
      "unity_assets = []",
      "for tex in textures:",
      "    asset_path = find_texture_in_assets(tex['blender_name'])",
      "    if asset_path:",
      "        unity_assets.append({",
      "            'blender_name': tex['blender_name'],",
      "            'unity_path': asset_path,",
      "            'sampler_state': map_sampler_state(tex['interpolation'], tex['extension'])",
      "        })",
      "    else:",
      "        print(f\"WARNING: {tex['blender_name']} not found in Assets\")",
      "",
      "# Generate shader graph",
      "shader_config = load_config('shader_graph_solution_TexImage.json')",
      "builder = ShaderGraphBuilder(shader_config)",
      "",
      "for asset in unity_assets:",
      "    builder.assign_texture(asset['unity_path'])",
      "    builder.configure_sampler(asset['sampler_state'])",
      "",
      "# Validate and export",
      "if builder.validate():",
      "    builder.export_to_unity('GeneratedShader.shadergraph')",
      "else:",
      "    print('Validation failed!')"
    ]
