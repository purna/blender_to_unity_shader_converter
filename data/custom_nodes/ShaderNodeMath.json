  "build_instructions": [
    {
      "step": 1,
      "action": "GET_OPERATION",
      "description": "Get the operation type from Blender node",
      "python": "operation = blender_node.operation"
    },
    {
      "step": 2,
      "action": "MAP_TO_UNITY_NODE",
      "description": "Map Blender operation to Unity node type",
      "python": "unity_node_type = operations_mapping.get(operation, 'AddNode')"
    },
    {
      "step": 3,
      "action": "CREATE_UNITY_NODE",
      "description": "Create the Unity math node",
      "python": "unity_node = create_shadergraph_node(unity_node_type)"
    },
    {
      "step": 4,
      "action": "CONNECT_VALUES",
      "description": "Connect value inputs",
      "python": "connect_input('A', blender_node.inputs['Value1'])"
    },
    {
      "step": 5,
      "action": "CONNECT_VALUE2",
      "description": "Connect second value if operation uses it",
      "python": "if operation_requires_two_inputs(operation): connect_input('B', blender_node.inputs['Value2'])"
    }
  ],
