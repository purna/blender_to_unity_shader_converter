      {
        "node_id": "hsv_conversion",
        "node_type": "CodeFunctionNode",
        "category": "Math",
        "label": "HSV to RGB",
        "property_type": "None",
        "custom_function": {
          "name": "HSVtoRGB",
          "code": "float3 HSVtoRGB(float3 c) { float4 K = float4(1.0, 2.0/3.0, 1.0/3.0, 3.0); float3 p = abs(frac(c.xxx + K.xyz) * 6.0 - K.www); return c.z * lerp(K.xxx, clamp(p - K.xxx, 0.0, 1.0), c.y); }"
        },
        "inputs": [
          {
            "name": "c",
            "type": "Vector3"
          }
        ],
        "outputs": [
          {
            "name": "Out",
            "type": "Vector3"
          }
        ]
      },
      {
        "node_id": "combine_hsv",
        "node_type": "CombineNode",
        "category": "Utils",
        "label": "Combine HSV",
        "property_type": "None",
        "inputs": [
          {
            "name": "R",
            "type": "Float"
          },
          {
            "name": "G",
            "type": "Float"
          },
          {
            "name": "B",
            "type": "Float"
          }
        ],
        "outputs": [
          {
            "name": "Out",
            "type": "Vector3"
          }
        ]
      }
    ],
    "connections": [
      {
        "connection_id": "conn_1",
        "from_node": "h_input,s_input,v_input",
        "from_output": "Out",
        "to_node": "combine_hsv",
        "to_input": "R,G,B",
        "description": "Combine H,S,V to vector"
      },
      {
        "connection_id": "conn_2",
