          "step": 1,
          "operation": "Calculate hue sector",
          "input": "H value",
          "output": "Sector (0-5)",
          "purpose": "Determine which color sector"
        },
        {
          "step": 2,
          "operation": "Calculate intermediate values",
          "input": "H, S, V",
          "output": "c, x, m",
          "purpose": "Prepare for RGB calculation"
        },
        {
          "step": 3,
          "operation": "Assemble RGB",
          "input": "Sector, c, x, m",
