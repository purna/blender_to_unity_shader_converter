  "connections": [],
  "build_instructions": [
    {
      "step": 1,
      "action": "CHECK_BLEND_MODE",
      "description": "Get blend mode from Blender node",
      "python": "blend_mode = blender_node.blend_mode"
    },
    {
      "step": 2,
      "action": "MAP_TO_UNITY_NODE",
      "description": "Map blend mode to Unity node type",
      "python": "unity_node_type = blend_mode_mapping.get(blend_mode, 'LerpNode')"
    },
    {
      "step": 3,
      "action": "CREATE_NODE",
      "description": "Create Unity node",
      "python": "unity_node = create_shadergraph_node(unity_node_type)"
    },
    {
      "step": 4,
      "action": "CONNECT_COLOR1",
      "description": "Connect first color",
      "python": "connect_input('A', blender_node.inputs['Color1'])"
    },
    {
      "step": 5,
      "action": "CONNECT_COLOR2",
      "description": "Connect second color",
      "python": "connect_input('B', blender_node.inputs['Color2'])"
    },
    {
      "step": 6,
      "action": "CONNECT_FACTOR",
      "description": "Connect factor",
      "python": "connect_input('T', blender_node.inputs['Fac'])"
    }
  ],
  "compatibility": {
    "fully_compatible": [
      "Color1",
      "Color2",
      "Fac"
    ],
    "partially_compatible": [
      "ADD",
      "MULTIPLY",
      "SUBTRACT"
    ],
    "incompatible": [
      "SCREEN",
      "OVERLAY",
      "DARKEN",
      "LIGHTEN",
      "COLOR_DODGE",
      "COLOR_BURN",
      "SOFT_LIGHT",
      "PIN_LIGHT",
      "LINEAR_LIGHT"
    ]
  },
  "limitations": [
    "Many blend modes (Screen, Overlay, etc.) require custom shader code",
    "Only basic mix/add/multiply/subtract are directly supported"
  ],
  "unity_recreation": {
    "description": "Use Unity's Lerp node for basic mixing",
