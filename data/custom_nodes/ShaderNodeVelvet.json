        {
          "name": "Fresnel Effect",
          "type": "Fresnel",
          "location": [500, 300],
          "power": 2.0
        }
      ],
      "note": "Add nodes for texture processing and Fresnel edge detection"
    },
    {
      "step": 3,
      "action": "CREATE_MATH_NODES",
      "nodes": [
        {
          "name": "Fresnel x Color",
          "type": "Multiply",
          "location": [700, 350]
        },
        {
          "name": "Rim x Intensity",
          "type": "Multiply",
          "location": [700, 250]
        },
        {
          "name": "Base + Rim",
          "type": "Add",
          "location": [900, 300]
        }
      ],
      "note": "Create math operators to combine effects"
    },
    {
      "step": 4,
      "action": "WIRE_NORMAL_CHAIN",
      "connections": [
        "Normal Map → Normal From Texture",
        "Normal From Texture → Fresnel Effect",
        "Normal From Texture → Master Node (Normal)"
