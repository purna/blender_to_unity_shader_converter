  "example_python_usage": {
    "description": "How a Python script would build this shader",
    "pseudo_code": [
      "import json",
      "from shader_graph_builder import ShaderGraphBuilder",
      "",
      "# Load configuration",
      "with open('shader_graph_solution_Velvet.json', 'r') as f:",
      "    config = json.load(f)",
      "",
      "# Initialize builder",
      "builder = ShaderGraphBuilder()",
      "builder.set_shader_name(config['shader_graph']['name'])",
      "builder.set_target_type(config['shader_graph']['type'])",
      "",
      "# Step 1: Create all property nodes",
      "for node_data in config['shader_graph']['nodes']:",
      "    if node_data['node_type'] == 'Property':",
      "        builder.create_property(",
      "            name=node_data['label'],",
      "            prop_type=node_data['property_type'],",
      "            default=node_data['default_value']",
      "        )",
      "",
      "# Step 2: Create utility and math nodes",
      "for node_data in config['shader_graph']['nodes']:",
      "    if node_data['node_type'] in ['Fresnel', 'Multiply', 'Add', 'NormalFromTexture']:",
      "        builder.create_node(",
      "            node_type=node_data['node_type'],",
      "            node_id=node_data['node_id'],",
      "            label=node_data['label']",
      "        )",
      "",
      "# Step 3: Establish connections",
      "for conn in config['shader_graph']['connections']:",
      "    builder.connect(",
      "        from_node=conn['from_node'],",
      "        from_output=conn['from_output'],",
      "        to_node=conn['to_node'],",
      "        to_input=conn['to_input']",
      "    )",
      "",
      "# Step 4: Validate",
      "validation_results = builder.validate(config['python_interpreter_config']['error_handling'])",
      "if not validation_results['success']:",
      "    print(f\"Validation errors: {validation_results['errors']}\")",
      "    exit(1)",
      "",
      "# Step 5: Export",
      "builder.export_to_unity('VelvetFabric.shadergraph')"
    ]
  }
